            "file": "setup/Fractal_65/fc/diamond_f4_elrs.option.yaml"
          },
          {
            "name": "diamond_f4_frsky",
            "title": "Happymodel Diamond F4 FrSky",
            "desc": "Happymodel Diamond F4 with SPI frsky (Upside-Down)",
            "file": "setup/Fractal_65/fc/diamond_f4_frsky.option.yaml"
          },
          {
            "name": "superbee_f4_elrs",
            "title": "Happymodel Superbee F4 ELRS",
            "desc": "Happymodel Superbee F4 ELRS (Upside-Down)",
            "file": "setup/Fractal_65/fc/superbee_f4_elrs.option.yaml"
          }
        ]
      },
      {
        "name": "gyro",
        "title": "Gyro",
        "default": "default",
        "entries": [
          {
            "name": "bmi270",
            "title": "BMI270",
            "desc": "The Bad",
            "selector": {
              "gyro_name": [
                "BMI270"
              ]
            },
            "file": "setup/Fractal_65/gyro/bmi270.option.yaml"
          },
          {
            "name": "default",
            "title": "Default",
            "desc": "The Good - for every other gyros (MPU6000, ICM20689, etc...)",
            "file": "setup/Fractal_65/gyro/default.option.yaml"
          },
          {
            "name": "icm42688p",
            "title": "ICM42688P",
            "desc": "The Ugly",
            "selector": {
              "gyro_name": [
                "ICM42688P"
              ]
            },
            "file": "setup/Fractal_65/gyro/icm42688p.option.yaml"
          }
        ]
      },
      {
        "name": "vtx",
        "title": "VTX type",
        "entries": [
          {
            "name": "hdzero",
            "title": "HDZero",
            "desc": "HDZero over MSP (Uart 2)",
            "file": "setup/Fractal_65/vtx/hdzero.option.yaml"
          },
          {
            "name": "onboard_vtx",
            "title": "Onboard/External Analog VTX",
            "desc": "Onboard or External Analog VTX (Uart 2)",
            "file": "setup/Fractal_65/vtx/onboard.option.yaml"
          }
        ]
      }
    ],
    "mutations": [
      {
        "name": "Gyro modifiers",
        "options": [
          {
            "name": "df4_icm42688p",
            "selector": {
              "fc": [
                "diamond_f4_elrs",
                "diamond_f4_frsky"
              ],
              "gyro": [
                "icm42688p"
              ]
            },
            "profile": {
              "motor": {
                "gyro_orientation": 48
              }
            }
          },
          {
            "name": "x12_bmi270",
            "selector": {
              "fc": [
                "x12_elrs"
              ],
              "gyro": [
                "bmi270"
              ]
            },
            "profile": {
              "motor": {
                "gyro_orientation": 36
              }
            }
          }
        ]
      }
    ],
    "category": "setup",
    "profile": "setup/Fractal_65/profile.yaml",
    "image": "setup/Fractal_65/image.jpg"
