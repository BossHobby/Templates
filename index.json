    "desc": "Customizable template for the Fractal 65 - Make sure to check motor rotation before sending it!",
    "options": [
      {
        "name": "fc",
        "title": "Flight Controller",
        "entries": [
          {
            "name": "diamond_f4_elrs",
            "title": "Happymodel Diamond F4 ELRS",
